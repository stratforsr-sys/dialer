generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  // Database migrated to support Deal pipeline (Apr 2026)
}

// ==================== USERS ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(SELLER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads        Lead[]         @relation("LeadOwner")
  activities   Activity[]     @relation("ActivityActor")
  callSessions CallSession[]
  meetings     Meeting[]      @relation("MeetingBookedBy")
  dealsCreated Deal[]         @relation("DealCreatedBy")
}

enum Role {
  ADMIN
  SELLER
}

// ==================== LEADS & CONTACTS ====================

model Lead {
  id            String   @id @default(cuid())
  companyName   String
  orgNumber     String?  @unique
  website       String?
  address       String?
  hasActiveDeal Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerId String
  owner   User   @relation("LeadOwner", fields: [ownerId], references: [id])

  contacts   Contact[]
  activities Activity[]
  meetings   Meeting[]
  deals      Deal[]
  tags       TagOnLead[]
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  role        String?
  directPhone String?
  switchboard String?
  email       String?
  linkedin    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  activities Activity[]
}

// ==================== PIPELINE ====================

model PipelineStage {
  id        String   @id @default(cuid())
  name      String
  order     Int
  color     String   @default("#6B7280")
  isDefault Boolean  @default(false)
  isWon     Boolean  @default(false)
  isLost    Boolean  @default(false)
  createdAt DateTime @default(now())

  deals Deal[]
}

// ==================== DEALS ====================

model Deal {
  id              String     @id @default(cuid())
  title           String
  valueType       ValueType  @default(ONE_TIME)
  oneTimeValue    Float?
  arrValue        Float?
  probability     Int        @default(20)
  expectedCloseAt DateTime?
  notes           String?
  status          DealStatus @default(OPEN)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  stageId     String
  stage       PipelineStage @relation(fields: [stageId], references: [id])

  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User          @relation("DealCreatedBy", fields: [createdById], references: [id])

  products    DealProduct[]
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ValueType {
  ONE_TIME
  ARR
}

// ==================== PRODUCTS ====================

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  basePrice   Float?
  isRecurring Boolean  @default(false)
  unit        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  dealProducts DealProduct[]
}

model DealProduct {
  id          String   @id @default(cuid())
  name        String
  price       Float?
  quantity    Int      @default(1)
  isRecurring Boolean  @default(false)
  unit        String?

  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

// ==================== ACTIVITY LOG ====================

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  timestamp DateTime     @default(now())
  metadata  String?      // JSON string: { note, status, from, to, etc. }

  actorId String
  actor   User   @relation("ActivityActor", fields: [actorId], references: [id])

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@index([leadId, timestamp])
  @@index([actorId, timestamp])
}

enum ActivityType {
  CALL
  CALL_NO_ANSWER
  NOTE
  STAGE_CHANGE
  MEETING_BOOKED
  MEETING_COMPLETED
  MEETING_NO_SHOW
  LEAD_CREATED
  LEAD_ASSIGNED
  LEAD_IMPORTED
  CONTACT_ADDED
  STATUS_CHANGE
  DEAL_CREATED
  DEAL_STAGE_CHANGE
  DEAL_WON
  DEAL_LOST
}

// ==================== MEETINGS ====================

model Meeting {
  id          String         @id @default(cuid())
  title       String?
  scheduledAt DateTime
  outcome     MeetingOutcome @default(PENDING)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  leadId     String
  lead       Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  bookedById String
  bookedBy   User   @relation("MeetingBookedBy", fields: [bookedById], references: [id])

  @@index([scheduledAt])
  @@index([outcome, scheduledAt])
}

enum MeetingOutcome {
  PENDING
  SHOW
  NO_SHOW
  CANCELLED
  RESCHEDULED
}

// ==================== CALL SESSIONS (Fluff-tracking) ====================

model CallSession {
  id         String    @id @default(cuid())
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  totalCalls Int       @default(0)
  totalIdle  Int       @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  events CallEvent[]

  @@index([userId, startedAt])
}

model CallEvent {
  id            String    @id @default(cuid())
  callStartedAt DateTime
  callEndedAt   DateTime?
  idleBefore    Int       @default(0)

  sessionId String
  session   CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ==================== TAGS ====================

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6B7280")

  leads TagOnLead[]
}

model TagOnLead {
  leadId String
  tagId  String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
}
